# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── TheSportsDB (football data — Phase 4) ───────────────────
# Free test key is "123"; get a paid key for production rate limits.
THESPORTSDB_API_KEY=123
THESPORTSDB_LEAGUE_ID=4429
THESPORTSDB_SEASON=2026

# ─── OpenRouter (Qwen — Phase 5+ AI features) ──────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default wallet for new users is set in Supabase (see docs/DEPLOYMENT.md).
# The Postgres trigger uses app.default_wallet_balance or falls back to 1000.

# ─── Vercel Cron ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret
